{
  "info": {
    "name": "FastAPI Users & Products API",
    "description": "Colección base para probar los endpoints principales de autenticación, usuarios, productos y auditoría.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {         
        "name": "Register",
        "event": [
            {
            "listen": "prerequest",
            "script": {
                "exec": [
                "const ts = Date.now().toString().slice(-6);",
                "pm.environment.set('registered_username', `mayra_${ts}`);",
                "pm.environment.set('registered_email', `mayra_${ts}@example.com`);"
                ],
                "type": "text/javascript"
            }
            },
            {
            "listen": "test",
            "script": {
                "exec": [
                "const json = pm.response.json();",
                "if (json?.resultado?.access_token) pm.environment.set('access_token', json.resultado.access_token);",
                "if (json?.resultado?.refresh_token) pm.environment.set('refresh_token', json.resultado.refresh_token);"
                ],
                "type": "text/javascript"
            }
            }
        ],
        "request": {
            "method": "POST",
            "header": [
            {
                "key": "Content-Type",
                "value": "application/json"
            }
            ],
            "body": {
            "mode": "raw",
            "raw": "{\n  \"first_name\": \"Mayra\",\n  \"last_name\": \"Prueba\",\n  \"username\": \"{{registered_username}}\",\n  \"email\": \"{{registered_email}}\",\n  \"password\": \"Clave1234\"\n}",
            "options": {
                "raw": {
                "language": "json"
                }
            }
            },
            "url": {
            "raw": "{{base_url}}/auth/register",
            "host": [
                "{{base_url}}"
            ],
            "path": [
                "auth",
                "register"
            ]
            }
        }
        },
        {
        "name": "Login",
        "event": [
            {
            "listen": "test",
            "script": {
                "exec": [
                "const json = pm.response.json();",
                "if (json?.access_token) pm.environment.set('access_token', json.access_token);",
                "if (json?.refresh_token) pm.environment.set('refresh_token', json.refresh_token);"
                ],
                "type": "text/javascript"
            }
            }
        ],
        "request": {
            "method": "POST",
            "header": [],
            "body": {
            "mode": "urlencoded",
            "urlencoded": [
                {
                "key": "username",
                "value": "{{registered_username}}",
                "type": "text"
                },
                {
                "key": "password",
                "value": "Clave1234",
                "type": "text"
                }
            ]
            },
            "url": {
            "raw": "{{base_url}}/auth/login",
            "host": [
                "{{base_url}}"
            ],
            "path": [
                "auth",
                "login"
            ]
            }
        }
        },
        {
          "name": "Me",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.resultado?.id) pm.environment.set('user_id', json.resultado.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.resultado?.access_token) pm.environment.set('access_token', json.resultado.access_token);",
                  "if (json?.resultado?.refresh_token) pm.environment.set('refresh_token', json.resultado.refresh_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh-token",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "refresh-token"
              ]
            }
          }
        },
        {
        "name": "Forgot Password",
        "request": {
            "method": "POST",
            "header": [
            {
                "key": "Content-Type",
                "value": "application/json"
            }
            ],
            "body": {
            "mode": "raw",
            "raw": "{\n  \"email\": \"{{registered_email}}\"\n}",
            "options": {
                "raw": {
                "language": "json"
                }
            }
            },
            "url": {
            "raw": "{{base_url}}/auth/forgot-password",
            "host": [
                "{{base_url}}"
            ],
            "path": [
                "auth",
                "forgot-password"
            ]
            }
        }
        },
        {
          "name": "Reset Password (manual)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{reset_token}}\",\n  \"new_password\": \"NuevaClave1234\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/reset-password",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "reset-password"
              ]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            }
          }
        },
        {
          "name": "Logout All",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout-all",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "logout-all"
              ]
            }
          }
        }
      ]
    },
