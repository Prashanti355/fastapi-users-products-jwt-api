# =========================================================
# PROYECTO / ENTORNO
# =========================================================
PROJECT_NAME=Users & Products API
VERSION=3.0.0
ENVIRONMENT=development
DEBUG=False
API_V1_STR=/api/v1
APP_PORT=8000

# =========================================================
# BASE DE DATOS
# =========================================================
POSTGRES_USER=fastapi_app
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=fastapi_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# En Docker Compose local, normalmente NO se define DATABASE_URL.
# DATABASE_URL=

# Para producción, usar una URL real:
# DATABASE_URL=postgresql+asyncpg://usuario:password@host:5432/database

# =========================================================
# SEGURIDAD / JWT
# =========================================================
SECRET_KEY=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =========================================================
# PAGINACIÓN
# =========================================================
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# =========================================================
# CORS
# =========================================================
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =========================================================
# LOGS
# =========================================================
LOG_DIR=logs

# =========================================================
# RATE LIMIT
# =========================================================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_STORAGE_URI=memory://
RATE_LIMIT_HEADERS_ENABLED=True
RATE_LIMIT_DEFAULTS=[]
RATE_LIMIT_LOGIN=200/minute
RATE_LIMIT_REGISTER=100/minute

# =========================================================
# CORREO / RECUPERACIÓN DE CONTRASEÑA
# =========================================================
RESEND_API_KEY=CHANGE_ME
EMAIL_FROM=Acme <onboarding@resend.dev>
FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/reset-password