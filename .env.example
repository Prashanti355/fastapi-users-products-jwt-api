# =========================================================
# CONFIGURACIÓN GENERAL
# =========================================================
PROJECT_NAME="Users & Products API"
VERSION=3.0.0
DEBUG=False
ENVIRONMENT=development
API_V1_STR=/api/v1

# =========================================================
# BASE DE DATOS
# =========================================================
POSTGRES_USER=fastapi_app
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=fastapi_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Opcional:
# Si se define DATABASE_URL, tiene prioridad sobre los campos POSTGRES_*
# DATABASE_URL=postgresql+asyncpg://fastapi_app:CHANGE_ME@localhost:5432/fastapi_db

# =========================================================
# APLICACIÓN
# =========================================================
APP_PORT=8000

# =========================================================
# JWT / SEGURIDAD
# =========================================================
SECRET_KEY=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =========================================================
# PAGINACIÓN
# =========================================================
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# =========================================================
# CORS
# =========================================================
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# =========================================================
# RATE LIMIT
# =========================================================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_STORAGE_URI=memory://
RATE_LIMIT_HEADERS_ENABLED=True
RATE_LIMIT_DEFAULTS=[]
RATE_LIMIT_LOGIN=200/minute
RATE_LIMIT_REGISTER=100/minute

# =========================================================
# LOGS
# =========================================================
# Descomenta si tu logging_config lo usa
# LOG_DIR=logs